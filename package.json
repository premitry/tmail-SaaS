{
  "name": "tmail-saas",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant temp-mail SaaS (Owner -> Buyer -> Visitor) on Cloudflare Workers",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "tail": "wrangler tail",
    "db:init": "wrangler d1 execute tmail_saas --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute tmail_saas --remote --file=./schema.sql"
  },
  "dependencies": {
    "postal-mime": "^2.4.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20250712.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.20.0"
  }
}
